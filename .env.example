# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Required for storage writes/deletes if your bucket policies do not allow them with the publishable key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Model selection (optional — defaults shown)
# Orchestrator: used for scope analysis, evidence reflection, synthesis, verification
RESEARCH_ORCHESTRATOR_MODEL=gpt-4.1
# Worker: used for page summarisation and query execution (cheaper/faster)
RESEARCH_WORKER_MODEL=gpt-4o-mini

# Search provider: tavily (default), brave, or exa
SEARCH_PROVIDER=tavily

# Tavily (default search provider)
TAVILY_API_KEY=your-tavily-api-key

# Brave Search (free tier: 2,000 queries/month — https://api.search.brave.com)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# Exa (free tier: 1,000 requests/month — https://exa.ai)
EXA_API_KEY=your-exa-api-key
