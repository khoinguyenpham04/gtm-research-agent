# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Required for storage writes/deletes if your bucket policies do not allow them with the publishable key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Required for LangGraph Postgres checkpointing and deep research runtime tables.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Tavily
TAVILY_API_KEY=your-tavily-api-key
